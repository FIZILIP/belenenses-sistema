#!/bin/bash
echo "⚽ GET CLUB - A instalar..."

# Verificar Python
if ! command -v python3 &> /dev/null; then
    echo "Python 3 não encontrado. Instale em python.org/downloads"
    exit 1
fi

# Criar pastas
APP_DIR="/Applications/GETCLUB.app/Contents/Resources"
mkdir -p "$APP_DIR"
mkdir -p /Applications/GETCLUB.app/Contents/MacOS

# Copiar ficheiros
cp -R /tmp/getclub_install/templates "$APP_DIR/"
cp -R /tmp/getclub_install/static "$APP_DIR/"
cp /tmp/getclub_install/app.py "$APP_DIR/"
cp /tmp/getclub_install/models.py "$APP_DIR/"
cp /tmp/getclub_install/requirements.txt "$APP_DIR/"

# Instalar dependências
cd "$APP_DIR"
python3 -m venv venv
source venv/bin/activate
pip3 install -r requirements.txt --quiet

# Criar executável
echo '#!/bin/bash
cd /Applications/GETCLUB.app/Contents/Resources
source venv/bin/activate
python3 app.py &
sleep 3
open http://127.0.0.1:5002' > /Applications/GETCLUB.app/Contents/MacOS/GETCLUB
chmod +x /Applications/GETCLUB.app/Contents/MacOS/GETCLUB

# Criar Info.plist
echo '<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
<key>CFBundleExecutable</key><string>GETCLUB</string>
<key>CFBundleName</key><string>GET CLUB</string>
<key>CFBundleDisplayName</key><string>GET CLUB</string>
<key>CFBundleIconFile</key><string>icon.icns</string>
</dict></plist>' > /Applications/GETCLUB.app/Contents/Info.plist

# Ícone
if [ -f /tmp/getclub_install/MyIcon.icns ]; then
    cp /tmp/getclub_install/MyIcon.icns /Applications/GETCLUB.app/Contents/Resources/icon.icns
fi

killall Dock 2>/dev/null
echo "✅ GET CLUB instalado!"
